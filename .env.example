# ─────────────────────────────────────────────────────────────────────────────
# SkillBench configuration — copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# General
COMPOSE_PROJECT_NAME=skillbench
ENVIRONMENT=development            # development | production
LOG_LEVEL=info

# ── Host ports (change if they collide with other local projects) ────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ── Public URLs ──────────────────────────────────────────────────────────────
# Used for OAuth callbacks, invite links, webhook origins, CORS.
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
# Comma-separated origins allowed by the API (CORS).
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=skillbench
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=skillbench
# Internal DSN used by the backend (host = service name on the compose network).
DATABASE_URL=postgresql+asyncpg://skillbench:change-me-postgres@db:5432/skillbench

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend security ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-32-byte-hex
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ── Google OAuth (admin sign-in) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Only emails on these domains may access the admin area (comma-separated).
ALLOWED_ADMIN_EMAIL_DOMAINS=leapswitch.com

# ── Test-mode / bootstrap password login ─────────────────────────────────────
# DISABLED by default. Enable ONLY for local setup/testing so the first admin
# can sign in without Google (visit /login?testmode). NEVER enable in production.
ALLOW_PASSWORD_LOGIN=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Email (invitations, notifications) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SkillBench <no-reply@example.com>"

# ── AI providers (added in the AI phase; multi-provider) ─────────────────────
# AI_PROVIDER: anthropic | claude_code_sdk | openai | stub | "" (disabled)
# Use "stub" for keyless local development of AI features.
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Judge0 (code execution) ──────────────────────────────────────────────────
# Set JUDGE0_ENABLED=true and run the Judge0 stack (compose.judge0.yml) to
# enable live code execution + auto-grading of coding questions.
JUDGE0_ENABLED=false
JUDGE0_URL=http://judge0:2358
JUDGE0_AUTH_TOKEN=

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Exposed to the browser, so keep it non-secret.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SkillBench
# Used by Next.js server components to reach the backend over the compose
# network (browser uses NEXT_PUBLIC_API_BASE_URL instead).
INTERNAL_API_BASE_URL=http://backend:8000
